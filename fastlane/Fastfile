default_platform(:android)

platform :android do
  desc "Build debug APK"
  lane :debug do
    gradle(task: "assembleDebug")
  end

  desc "Build release APK and AAB"
  lane :build_release do
    gradle(task: "assembleRelease")
    gradle(task: "bundleRelease")
  end

  desc "Deploy to Play Store internal track"
  desc "Usage: fastlane internal version_name:1.2"
  lane :internal do |options|
    version_name = options[:version_name]
    UI.user_error!("Missing version_name. Usage: fastlane internal version_name:1.2") if version_name.to_s.empty?

    version_codes = google_play_track_version_codes(track: "internal")
    next_code = (version_codes.max || 0) + 1
    UI.message("Building versionName #{version_name} with versionCode #{next_code}")
    gradle(
      task: "bundleRelease",
      properties: {
        "versionCode" => next_code,
        "versionName" => version_name
      }
    )
    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Promote internal to production"
  lane :production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production"
    )
  end
end
